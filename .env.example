# =============================================================================
# AI Provider (OpenAI por padrão; troque para OpenRouter mudando as 3 linhas)
# =============================================================================

# OpenAI
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# OpenRouter (descomente para usar)
# AI_API_KEY=sk-or-...
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o
# ou: AI_MODEL=anthropic/claude-sonnet-4-5

# =============================================================================
# Evolution API (WhatsApp Gateway)
# =============================================================================
EVOLUTION_API_KEY=change-me-strong-secret
EVOLUTION_INSTANCE_NAME=zabbix-alerts
# Deixe vazio — docker-compose injeta a URL interna automaticamente
# EVOLUTION_BASE_URL=http://evolution-api:8080

# =============================================================================
# WhatsApp
# =============================================================================
# Número de destino: DDI + DDD + número (sem +, espaços ou traços)
WHATSAPP_DESTINATION_NUMBER=5511999999999

# =============================================================================
# Comportamento do agente
# (também configurável pela UI — os valores do banco têm prioridade sobre este arquivo)
# =============================================================================
ALLOWED_SEVERITIES=High,Disaster
DEDUP_TTL_SECONDS=1800
LOG_LEVEL=INFO

# =============================================================================
# Banco de configuração (UI de setup)
# =============================================================================
CONFIG_DB_PASSWORD=agent_secret
EVOLUTION_DB_PASSWORD=evolution_secret
# CONFIG_DATABASE_URL é injetado pelo docker-compose automaticamente

# =============================================================================
# Zabbix local (usado apenas para testes com --profile zabbix)
# =============================================================================
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=zabbix_secret
